{
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "^57.0.7",
    "expo-crypto": "^57.0.1",
    "expo-font": "^57.0.1",
    "expo-splash-screen": "^57.0.4",
    "expo-status-bar": "^57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "^5.8.0",
